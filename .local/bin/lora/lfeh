#!/bin/sh

##############################################
# Image Viewer (Move to Trash img/txt pairs) #
##############################################

# Usage:
#   lora-feh [img-dir]
#
# Description: 
#   Opens a feh instance equipped with several useful actions for LoRAs. 
#
#   If a directory is not provided, the user is prompted to select 
#   a directory from BASE_DIR (excluding those mentioned in EXCLUDE).
#
#   Actions: 
#     0/[Enter]: Move the current image and its corresponding .txt file to Trash.
#
#     1: Open the current image in Gimp.
#
#     2: If the current image and its corresponding .txt file are in an "unused" directory 
#        (e.g., path/to/training/unused/lora-name/), then move it back to its original directory 
#        (e.g., path/to/training/lora-name/). Otherwise, move the image and text file to 
#        the "unused" directory (i.e., path/to/training/unused/lora-name), creating the directory
#        if it did not exist.
#
#     3: Copy the current image to clipboard. 

alias feh='feh --fullscreen -S name --version-sort'

# Directory of LoRA training directories. #
BASE_DIR="$HOME/programs/sd-scripts/training"

# Directories to exclude from BASE_DIR. #
EXCLUDE='out'

while getopts "p:d:f:a:r:" opt; do
  case "$opt" in
    p)
      export prepend_pos="${OPTARG%%,*}"
      export prepend_tag="${OPTARG#*,}"
      ;;
    d)
      export delete_tag="$OPTARG"
      ;;
		f)
			filter="$OPTARG"
			;;
    a)
      export custom_action="$OPTARG"
      ;;
		r)
      export old_tag="${OPTARG%%,*}"
      export new_tag="${OPTARG#*,}"
      ;;
		*)
			echo "Unknown flag: $opt" >&2
			exit 1
			;;
  esac
done
shift $((OPTIND - 1))

# Get image directory, if not specified. #
if [ $# -eq 0 ]; then
  selection=$(
    find "$BASE_DIR" -mindepth 1 -type d ! -empty | \
    grep -v -E "$BASE_DIR/($EXCLUDE)" | \
    sed "s#$BASE_DIR/##" | \
    dmenu -i -p "Select a Directory:"
  ) || exit 1
  
	set -- "$BASE_DIR/$selection"
fi

if [ -n "$filter" ]; then
	# Get all txt files within selected dir. #
	# Get all images with matching filter query. #
	find "$@" -maxdepth 5 -type f -name "*.txt" -print0 | \
	xargs -0 awk "$filter {print FILENAME}" | \
	sed -e 's#.*/\([^/]*\)\.[^.]*$#\1#' | \
	while IFS= read -r filename; do
		find "$@" -type f \( \
			-name "$filename.jpg" -o \
			-name "$filename.jpeg" -o \
			-name "$filename.png" -o \
			-name "$filename.webp" -o \
			-name "$filename.gif" \
		\)
	done
else
	find "$@" -type f \( \
		-name '*.jpg' -o \
		-name '*.jpeg' -o \
		-name '*.png' -o \
		-name '*.webp' -o \
		-name '*.gif' \
	\) 
fi |
feh --info 'echo Dim: %wx%h, File: %N' -r \
	--action  '[Move to Trash]file=%F ; trash -vf "$file" "${file%%.*}.txt"' \
	--action1 '[Open in Gimp]gimp %F &' \
	--action2 '[Move to/from Unused]move_unused.sh %F' \
	--action3 '[Copy Image to Clipboard]xclip -sel clip -t image/png -i %F' \
	--action4 '[Restore Original]f=%F; cp -vf "$(echo $f | sed "s|/training/|/training/orig/|")" "$f"' \
	--action5 '[Open in Editor]file=%F ; "$TERMINAL" -e "$EDITOR" "${file%%.*}.txt" 2>/dev/null' \
	--action6 '[Prepend Tag]f=%F; txt="${f%%.*}.txt"; if [ -n "${prepend_tag}" ]; then c=$(head -n 1 "$txt" | tr -dc "," | wc -c); if [ "${prepend_pos:-0}" -gt "$c" ]; then sed -i -e "1s/$/, ${prepend_tag}/" "$txt"; else sed -i -E "1s/(([^,]*,[[:space:]]*){"${prepend_pos:-0}"})/\1${prepend_tag}, /" "$txt"; fi; fi' \
	--action7 '[Replace Tag]file=%F ; [ -n "$new_tag" ] && sed -i -e "s/^${old_tag}, /${new_tag}, /" -e "s/, ${old_tag}, /, ${new_tag}, /g" -e "s/, ${old_tag}\$/, ${new_tag}/" -e "s/^${old_tag}\$/${new_tag}/" "${file%%.*}.txt"' \
	--action8 '[Delete Tag]file=%F ; [ -n "$delete_tag" ] && sed -i -e "s/^${delete_tag}, //" -e "s/, ${delete_tag}, /, /g" -e "s/, ${delete_tag}\$//" -e "s/^${delete_tag}\$//" "${file%%.*}.txt"' \
	${custom_action:+--action9 "[Custom Action]$custom_action"} \
--filelist -

