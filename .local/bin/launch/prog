#!/bin/sh

####################
# Launch a Program #
####################

# Usage: 
#   prog
#
# Description: 
#   Launches a program using either symlinks or launcher scripts 
#   from `PROG_DIR`.

PROG_DIR="$HOME"/programs/.prog

prog=$(
  find "$PROG_DIR" -mindepth 1 -maxdepth 1 -printf "%f\n" | \
  sort | \
  dmenu -i -p 'Select Program:'
) && "$PROG_DIR/$prog"

